{
  "name": "stock-movement-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.9.0 || ^22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:mojibake && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "check:mojibake": "node scripts/check-mojibake.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "uploads:cleanup": "node scripts/cleanup-orphan-uploads.js",
    "uploads:cleanup:execute": "node scripts/cleanup-orphan-uploads.js --execute",
    "general-request:backfill-informational-tags": "node scripts/backfill-general-request-informational-tags.js",
    "general-request:backfill-informational-tags:execute": "node scripts/backfill-general-request-informational-tags.js --execute",
    "general-request:backfill-informational-tags:legacy": "node scripts/backfill-general-request-informational-tags.js --legacy-heuristic",
    "general-request:backfill-informational-tags:legacy:execute": "node scripts/backfill-general-request-informational-tags.js --legacy-heuristic --execute",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@line/bot-sdk": "^10.6.0",
    "@prisma/client": "5.22.0",
    "@tailwindcss/postcss": "^4",
    "@types/react-signature-canvas": "^1.0.7",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "mysql2": "^3.16.1",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "sweetalert2": "^11.26.22",
    "tailwindcss": "^4",
    "thai-baht-text": "^2.0.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "prisma": "5.22.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
