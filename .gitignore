# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build_output*.txt
build_print*.txt
build_debug*.log
ts_errors.txt
dev_restart.txt
tmp_*
*.bak
*.bak_*
*.orig
*.tmp
.mpstock*.txt

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# backups & logs
*.sql
*.log
/backups/
prisma/migrations/**/*.sql
!prisma/migrations/20260321121000_add_created_by_user_id_to_po/migration.sql
!prisma/migrations/20260328160000_add_room_section_to_assets/migration.sql
!prisma/migrations/20260330183000_add_product_sub_sub_category_code/migration.sql
!prisma/migrations/20260331120000_add_notification_reads/migration.sql

# deploy tool dist
/tools/dist/
/tools/build/
/tools/__pycache__/
/tools/*.spec

# large binaries and archives
*.exe
*.tar
*.rar
*.zip
*.gz
