  dispensed_amount Decimal?  @db.Decimal(10, 2)
  actual_spent     Decimal?  @db.Decimal(10, 2)
  change_returned  Decimal?  @db.Decimal(10, 2)
  
  receipt_urls     Json?
  notes            String?   @db.Text
  
  status           String    @default("pending") @db.VarChar(50)
  
