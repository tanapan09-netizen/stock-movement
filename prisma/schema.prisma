model tbl_approval_requests {
  request_id      Int       @id @default(autoincrement())
  request_number  String    @unique @db.VarChar(50)
  request_type    String    @db.VarChar(50) // 'ot', 'leave', 'expense', 'other'
  requested_by    Int
  request_date    DateTime? @db.Date
  start_time      DateTime? @db.Timestamp(0)
  end_time        DateTime? @db.Timestamp(0)
  amount          Decimal?  @db.Decimal(10, 2)
  reason          String    @db.Text
  reference_job   String?   @db.VarChar(50)
  status          String    @default("pending") @db.VarChar(20)
  supervisor_id   Int?
  approved_at     DateTime? @db.Timestamp(0)
  rejection_reason String?  @db.Text
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  // Multi-step additions
  current_step    Int       @default(1)
  total_steps     Int       @default(1)
  workflow_id     Int?

  tbl_users       tbl_users  @relation("Requester", fields: [requested_by], references: [p_id])
  tbl_approver    tbl_users? @relation("Approver", fields: [supervisor_id], references: [p_id])
  workflow        tbl_approval_workflows? @relation(fields: [workflow_id], references: [id])
  step_logs       tbl_approval_step_logs[]

  @@index([request_type])
  @@index([status])
  @@index([workflow_id])
}

model tbl_approval_workflows {
  id              Int      @id @default(autoincrement())
  workflow_name   String   @db.VarChar(100)
  request_type    String   @db.VarChar(50) // ot, leave, expense
  condition_field String?  @db.VarChar(50) // e.g. amount
  condition_op    String?  @db.VarChar(10) // e.g. >, <=, =
  condition_value String?  @db.VarChar(50) // e.g. 5000
  total_steps     Int      @default(1)
  active          Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamp(0)
  
  steps           tbl_approval_workflow_steps[]
  requests        tbl_approval_requests[]

  @@index([request_type, active])
}

model tbl_approval_workflow_steps {
  id            Int      @id @default(autoincrement())
  workflow_id   Int
  step_order    Int
  approver_role String   @db.VarChar(50) // manager, admin, hr...
  approver_id   Int?     // specific user id if needed
  
  workflow      tbl_approval_workflows @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  
  @@index([workflow_id])
}

model tbl_approval_step_logs {
  id          Int       @id @default(autoincrement())
  request_id  Int
  step_order  Int
  action      String    @db.VarChar(20) // approved, rejected
  acted_by    Int
  acted_at    DateTime  @default(now()) @db.Timestamp(0)
  comment     String?   @db.Text
  
  request     tbl_approval_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade)
  actor       tbl_users             @relation(fields: [acted_by], references: [p_id])
  
  @@index([request_id])
  @@index([acted_by])
}
